# 관리자 계정 (최초 DB 시드)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# GitHub Personal Access Token (repo 권한 필요)
GITHUB_TOKEN=

# GitHub 저장소 설정
GITHUB_OWNER=opensphere-platform
GITHUB_REPO=logos
GITHUB_BRANCH=main

# Statically CDN
STATICALLY_CDN_BASE=https://cdn.statically.io/gh/opensphere-platform/logos@main

# 로컬 logos.json 경로 (선택)
# LOGOS_JSON_PATH=../OpenSphere-logos/OpenSphere-logos-github/logos.json

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password-no-spaces
SMTP_FROM=your@gmail.com

# 세션·OTP
SESSION_DAYS=7
OTP_EXPIRE_MINUTES=10

# 공개 사이트 URL (API·llms.txt 등)
SITE_BASE_URL=https://images.opl.io.kr
